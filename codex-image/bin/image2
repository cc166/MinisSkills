#!/usr/bin/env python3
import base64, json, os, re, subprocess, sys, tempfile, time, urllib.request

OUT_DIR = "/var/minis/attachments"
FALLBACK_SCRIPT = "/var/minis/skills/codex-image/scripts/openai_image_api.py"


def load_profile_env():
    try:
        for line in open('/etc/profile', encoding='utf-8', errors='ignore'):
            line = line.strip()
            if line.startswith('export ') and '=' in line:
                name, val = line[7:].split('=', 1)
                name = name.strip(); val = val.strip()
                if len(val) >= 2 and val[0] == val[-1] and val[0] in ('"', "'"):
                    val = val[1:-1]
                os.environ.setdefault(name, val)
    except Exception:
        pass


def usage(code=0):
    print('''用法:
  image2 画 "提示词" [输出文件]
  image2 改 输入图 "修改要求" [输出文件]

默认:
  image2 画 直接走 OpenAI-compatible /v1/responses：
  model=gpt-5.5 + tools=[{"type":"image_generation"}]

可选环境变量:
  IMAGE2_RESPONSES_MODEL=gpt-5.5  默认 gpt-5.5
  IMAGE2_RESPONSES_BASE_URL       默认 OPENAI_BASE_URL；若未设则 https://ai.input.im/v1
  IMAGE2_USE_RESPONSES=1          默认 1；设 0 可改用 minis-model-use fallback
  IMAGE2_MINIS_MODEL=gpt-image-2  fallback 模型
  IMAGE2_MINIS_ENDPOINT=auto      fallback 端点
''')
    raise SystemExit(code)


def normalize_out(path, prefix):
    if not path:
        return os.path.join(OUT_DIR, f"{prefix}_{time.strftime('%Y%m%d_%H%M%S')}.png")
    if os.path.dirname(path):
        return path
    return os.path.join(OUT_DIR, path)


def normalize_in(path):
    if os.path.exists(path):
        return path
    p = os.path.join(OUT_DIR, path)
    return p if os.path.exists(p) else path


def parse_json_loose(text):
    text = (text or '').strip()
    if not text:
        return None
    try:
        return json.loads(text)
    except Exception:
        pass
    start = text.find('{'); end = text.rfind('}')
    if start >= 0 and end > start:
        try:
            return json.loads(text[start:end+1])
        except Exception:
            pass
    return None


def find_image_payload(x):
    if isinstance(x, dict):
        media = x.get('media_files')
        if isinstance(media, list):
            for item in media:
                if isinstance(item, dict) and isinstance(item.get('path'), str):
                    return {'path': item['path']}
        for k in ('path', 'image_path', 'output_path', 'file', 'url'):
            v = x.get(k)
            if isinstance(v, str) and v:
                if v.startswith('/var/minis/') or v.startswith('minis://'):
                    return {'path': v}
                if v.startswith('http'):
                    return {'url': v}
        for k in ('b64_json', 'base64', 'image_base64'):
            v = x.get(k)
            if isinstance(v, str) and v:
                return {'b64': v}
        if isinstance(x.get('image_url'), dict):
            u = x['image_url'].get('url')
            if isinstance(u, str) and u:
                return {'url': u} if u.startswith('http') else {'b64': u}
        # Responses API image_generation_call often uses result field.
        v = x.get('result')
        if isinstance(v, str) and (v.startswith('iVBOR') or v.startswith('/9j/') or v.startswith('data:image')):
            return {'b64': v}
        for v in x.values():
            r = find_image_payload(v)
            if r:
                return r
    elif isinstance(x, list):
        for v in x:
            r = find_image_payload(v)
            if r:
                return r
    elif isinstance(x, str):
        s = x.strip()
        if s.startswith('/var/minis/') or s.startswith('minis://'):
            return {'path': s}
        if s.startswith('http'):
            return {'url': s}
        if s.startswith('data:image') or s.startswith('iVBOR') or s.startswith('/9j/'):
            return {'b64': s}
    return None


def minis_to_path(p):
    return '/var/minis/' + p[len('minis://'):] if p.startswith('minis://') else p


def save_payload(payload, output):
    if 'path' in payload:
        src = minis_to_path(payload['path'])
        data = open(src, 'rb').read()
        open(output, 'wb').write(data)
        return len(data)
    if 'b64' in payload:
        b64 = payload['b64']
        if b64.startswith('data:image'):
            b64 = b64.split(',', 1)[1]
        img = base64.b64decode(b64)
        open(output, 'wb').write(img)
        return len(img)
    if 'url' in payload:
        with urllib.request.urlopen(payload['url'], timeout=240) as r:
            data = r.read()
        open(output, 'wb').write(data)
        return len(data)
    raise RuntimeError('未找到图像输出')


def curl_json(url, api_key, payload, timeout=900):
    fd, payload_path = tempfile.mkstemp(prefix='image2_resp_payload_', suffix='.json'); os.close(fd)
    fd, out_path = tempfile.mkstemp(prefix='image2_resp_out_', suffix='.json'); os.close(fd)
    try:
        open(payload_path, 'w', encoding='utf-8').write(json.dumps(payload, ensure_ascii=False))
        cmd = [
            'curl', '-sS', '-L', '--max-time', str(timeout), '-o', out_path, '-w', '%{http_code}',
            '-H', 'Authorization: Bearer ' + api_key,
            '-H', 'Content-Type: application/json',
            '-H', 'Accept: application/json',
            '--data', '@' + payload_path,
            url,
        ]
        r = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout+30)
        status_text = (r.stdout or '').strip()[-3:]
        status = int(status_text) if status_text.isdigit() else 0
        raw = open(out_path, 'rb').read().decode('utf-8', errors='replace')
        return status, raw, r.stderr
    finally:
        for p in (payload_path, out_path):
            try: os.remove(p)
            except Exception: pass


def responses_generate(prompt, output):
    api_key = os.environ.get('OPENAI_API_KEY') or os.environ.get('INPUT_API_KEY')
    if not api_key:
        raise RuntimeError('OPENAI_API_KEY/INPUT_API_KEY not set')
    base = (os.environ.get('IMAGE2_RESPONSES_BASE_URL') or os.environ.get('OPENAI_BASE_URL') or 'https://ai.input.im/v1').rstrip('/')
    model = os.environ.get('IMAGE2_RESPONSES_MODEL') or 'gpt-5.5'
    payload = {
        'model': model,
        'input': [{'role': 'user', 'content': [{'type': 'input_text', 'text': '使用 image_generation 工具生成图片：' + prompt}]}],
        'tools': [{'type': 'image_generation'}],
        'tool_choice': 'auto',
        'stream': False,
    }
    status, raw, stderr = curl_json(base + '/responses', api_key, payload, timeout=900)
    if status < 200 or status >= 300:
        raise RuntimeError(f'responses HTTP {status}: {(raw or stderr)[:1200]}')
    data = json.loads(raw)
    payload = find_image_payload(data)
    if not payload:
        raise RuntimeError('responses 未返回可识别图片: ' + json.dumps(data, ensure_ascii=False)[:1200])
    size = save_payload(payload, output)
    return {'backend': 'responses', 'model': model, 'endpoint': '/v1/responses', 'size': size}


def minis_generate(prompt, output):
    model = os.environ.get('IMAGE2_MINIS_MODEL') or 'gpt-image-2'
    endpoint = os.environ.get('IMAGE2_MINIS_ENDPOINT') or 'auto'
    inp = '/tmp/image2_minis_input_%d.json' % os.getpid()
    out = '/tmp/image2_minis_output_%d.json' % os.getpid()
    with open(inp, 'w', encoding='utf-8') as f:
        json.dump({'messages': [{'role': 'user', 'content': prompt}]}, f, ensure_ascii=False)
    cmd = ['minis-model-use', 'run', '--model', model, '--endpoint', endpoint, '--input', inp, '--output', out, '--compact']
    r = subprocess.run(cmd, capture_output=True, text=True, timeout=900)
    text = (r.stdout or '') + ('\n' + r.stderr if r.stderr else '')
    data = None
    if os.path.exists(out):
        try:
            data = json.load(open(out, encoding='utf-8'))
        except Exception:
            data = None
    if data is None:
        data = parse_json_loose(text)
    if r.returncode != 0:
        raise RuntimeError((text or 'minis-model-use failed').strip()[:1200])
    payload = find_image_payload(data)
    if not payload:
        raise RuntimeError('minis-model-use 未返回可识别的图片数据: ' + str(data)[:1200])
    size = save_payload(payload, output)
    return {'backend': 'minis-model-use', 'model': model, 'endpoint': endpoint, 'size': size}


def generate(prompt, output):
    if os.environ.get('IMAGE2_USE_RESPONSES', '1') != '0':
        try:
            return responses_generate(prompt, output)
        except Exception as e:
            print('[image2] responses failed, fallback to minis-model-use: %s' % e, file=sys.stderr)
    return minis_generate(prompt, output)


def edit_image(image, prompt, output):
    cmd = [sys.executable, FALLBACK_SCRIPT, 'edit', '--image', image, prompt, '-o', output]
    r = subprocess.run(cmd, capture_output=True, text=True, timeout=1200)
    text = (r.stdout or '') + ('\n' + r.stderr if r.stderr else '')
    if r.returncode != 0:
        print(text, file=sys.stderr)
        return r.returncode
    print(text)
    return 0


def main():
    load_profile_env()
    os.makedirs(OUT_DIR, exist_ok=True)
    if len(sys.argv) < 2 or sys.argv[1] in ('-h', '--help', 'help', '帮助'):
        usage(0)
    mode = sys.argv[1]
    if mode in ('画', '生成', 'gen', 'generate'):
        if len(sys.argv) < 3:
            usage(1)
        prompt = sys.argv[2]
        output = normalize_out(sys.argv[3] if len(sys.argv) >= 4 else None, 'image2')
        res = generate(prompt, output)
        res.update({'success': True, 'path': output})
        print(json.dumps(res, ensure_ascii=False, indent=2))
        return
    if mode in ('改', '编辑', 'edit'):
        if len(sys.argv) < 4:
            usage(1)
        image = normalize_in(sys.argv[2])
        prompt = sys.argv[3]
        output = normalize_out(sys.argv[4] if len(sys.argv) >= 5 else None, 'image2_edit')
        raise SystemExit(edit_image(image, prompt, output))
    prompt = ' '.join(sys.argv[1:])
    output = normalize_out(None, 'image2')
    res = generate(prompt, output)
    res.update({'success': True, 'path': output})
    print(json.dumps(res, ensure_ascii=False, indent=2))


if __name__ == '__main__':
    main()
