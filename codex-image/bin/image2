#!/usr/bin/env python3
import base64, json, os, subprocess, sys, time, urllib.request

OUT_DIR = "/var/minis/attachments"
FALLBACK_SCRIPT = "/var/minis/skills/codex-image/scripts/openai_image_api.py"


def load_profile_env():
    try:
        for line in open('/etc/profile', encoding='utf-8', errors='ignore'):
            line = line.strip()
            if line.startswith('export ') and '=' in line:
                name, val = line[7:].split('=', 1)
                name = name.strip(); val = val.strip()
                if len(val) >= 2 and val[0] == val[-1] and val[0] in ('"', "'"):
                    val = val[1:-1]
                os.environ.setdefault(name, val)
    except Exception:
        pass


def usage(code=0):
    print('''用法:
  image2 画 "提示词" [输出文件]
  image2 改 输入图 "修改要求" [输出文件]

默认:
  image2 画 先用 AI 优化提示词，再走 Minis App 自带 minis-model-use：
  minis-model-use run --model gpt-image-2 --endpoint auto

可选环境变量:
  IMAGE2_OPTIMIZE_PROMPT=1          默认 1；设 0 可跳过提示词优化
  IMAGE2_PROMPT_MODEL=gpt-5.4       默认 gpt-5.4
  IMAGE2_MINIS_MODEL=gpt-image-2      默认 gpt-image-2
  IMAGE2_MINIS_ENDPOINT=auto          默认 auto；让 Minis 自己选择端点
''')
    raise SystemExit(code)


def normalize_out(path, prefix):
    if not path:
        ts = time.strftime('%Y%m%d_%H%M%S')
        return os.path.join(OUT_DIR, f'{prefix}_{ts}.png')
    if os.path.dirname(path):
        return path
    return os.path.join(OUT_DIR, path)


def normalize_in(path):
    if os.path.exists(path):
        return path
    p = os.path.join(OUT_DIR, path)
    return p if os.path.exists(p) else path


def parse_json_loose(text):
    text = (text or '').strip()
    if not text:
        return None
    try:
        return json.loads(text)
    except Exception:
        pass
    start = text.find('{')
    end = text.rfind('}')
    if start >= 0 and end > start:
        try:
            return json.loads(text[start:end+1])
        except Exception:
            pass
    return None


def find_image_payload(x):
    if isinstance(x, dict):
        media = x.get('media_files')
        if isinstance(media, list):
            for item in media:
                if isinstance(item, dict):
                    p = item.get('path')
                    if isinstance(p, str) and p:
                        return {'path': p}
        for k in ('path', 'image_path', 'output_path', 'file', 'url'):
            v = x.get(k)
            if isinstance(v, str) and v:
                if v.startswith('/var/minis/') or v.startswith('minis://'):
                    return {'path': v}
                if v.startswith('http'):
                    return {'url': v}
        for k in ('b64_json', 'base64', 'image_base64'):
            v = x.get(k)
            if isinstance(v, str) and v:
                return {'b64': v}
        if isinstance(x.get('image_url'), dict):
            u = x['image_url'].get('url')
            if isinstance(u, str) and u:
                if u.startswith('http'):
                    return {'url': u}
                return {'b64': u}
        for v in x.values():
            r = find_image_payload(v)
            if r:
                return r
    elif isinstance(x, list):
        for v in x:
            r = find_image_payload(v)
            if r:
                return r
    elif isinstance(x, str):
        s = x.strip()
        if s.startswith('/var/minis/') or s.startswith('minis://'):
            return {'path': s}
        if s.startswith('http'):
            return {'url': s}
        if s.startswith('data:image') or s.startswith('iVBOR') or s.startswith('/9j/'):
            return {'b64': s}
    return None


def minis_to_path(p):
    if p.startswith('minis://'):
        return '/var/minis/' + p[len('minis://'):]
    return p


def save_payload(payload, output):
    if 'path' in payload:
        src = minis_to_path(payload['path'])
        if src != output:
            data = open(src, 'rb').read()
            open(output, 'wb').write(data)
        return os.path.getsize(output)
    if 'b64' in payload:
        b64 = payload['b64']
        if b64.startswith('data:image'):
            b64 = b64.split(',', 1)[1]
        data = base64.b64decode(b64)
        open(output, 'wb').write(data)
        return len(data)
    if 'url' in payload:
        with urllib.request.urlopen(payload['url'], timeout=240) as r:
            data = r.read()
        open(output, 'wb').write(data)
        return len(data)
    raise RuntimeError('未找到图像输出')


def run_minis_text_model(prompt):
    model = os.environ.get('IMAGE2_PROMPT_MODEL') or os.environ.get('OPENAI_PROMPT_MODEL') or 'gpt-5.4'
    system = ('你是专业图像提示词优化器。把用户的简短需求改写成适合 gpt-image-2 的高质量中文图像生成提示词。'
              '只输出最终提示词，不要解释，不要 Markdown。保留用户的角色、审美和风格要求；补充主体、场景、构图、镜头、光影、材质、细节、质量要求；避免露骨色情和违法内容。')
    inp = '/tmp/image2_prompt_input_%d.json' % os.getpid()
    out = '/tmp/image2_prompt_output_%d.json' % os.getpid()
    with open(inp, 'w', encoding='utf-8') as f:
        json.dump({'messages': [
            {'role': 'system', 'content': system},
            {'role': 'user', 'content': prompt},
        ]}, f, ensure_ascii=False)
    cmd = ['minis-model-use', 'run', '--model', model, '--input', inp, '--output', out, '--compact']
    r = subprocess.run(cmd, capture_output=True, text=True, timeout=180)
    text = (r.stdout or '') + ('\n' + r.stderr if r.stderr else '')
    data = None
    if os.path.exists(out):
        try:
            with open(out, 'r', encoding='utf-8') as f:
                data = json.load(f)
        except Exception:
            data = None
    if data is None:
        data = parse_json_loose(text)
    if r.returncode != 0:
        raise RuntimeError((text or 'prompt optimize failed').strip()[:800])
    # minis-model-use usually returns data.output_text for text models.
    if isinstance(data, dict):
        d = data.get('data') if 'data' in data else data
        for key in ('output_text', 'text', 'content'):
            v = d.get(key) if isinstance(d, dict) else None
            if isinstance(v, str) and v.strip():
                return v.strip().strip('"')
        # Chat-like fallback.
        try:
            choices = d.get('choices') or []
            if choices:
                v = choices[0].get('message', {}).get('content')
                if isinstance(v, str) and v.strip():
                    return v.strip().strip('"')
        except Exception:
            pass
    raise RuntimeError('prompt optimize returned no text: ' + str(data)[:800])


def optimize_prompt(prompt):
    if os.environ.get('IMAGE2_OPTIMIZE_PROMPT', '1') == '0':
        return prompt, ''
    try:
        optimized = run_minis_text_model(prompt)
        if optimized:
            return optimized, optimized
    except Exception as e:
        print('[image2] prompt optimize skipped: %s' % e, file=sys.stderr)
    return prompt, ''


def minis_generate(prompt, output):
    model = os.environ.get('IMAGE2_MINIS_MODEL') or 'gpt-image-2'
    endpoint = os.environ.get('IMAGE2_MINIS_ENDPOINT') or 'auto'
    inp = '/tmp/image2_minis_input_%d.json' % os.getpid()
    out = '/tmp/image2_minis_output_%d.json' % os.getpid()
    with open(inp, 'w', encoding='utf-8') as f:
        json.dump({'messages': [{'role': 'user', 'content': prompt}]}, f, ensure_ascii=False)
    cmd = ['minis-model-use', 'run', '--model', model, '--endpoint', endpoint, '--input', inp, '--output', out, '--compact']
    r = subprocess.run(cmd, capture_output=True, text=True, timeout=900)
    text = (r.stdout or '') + ('\n' + r.stderr if r.stderr else '')
    data = None
    if os.path.exists(out):
        try:
            with open(out, 'r', encoding='utf-8') as f:
                data = json.load(f)
        except Exception:
            data = None
    if data is None:
        data = parse_json_loose(text)
    if r.returncode != 0:
        raise RuntimeError((text or 'minis-model-use failed').strip()[:1200])
    payload = find_image_payload(data)
    if not payload:
        raise RuntimeError('minis-model-use 未返回可识别的图片数据: ' + str(data)[:1200])
    size = save_payload(payload, output)
    return {'backend': 'minis-model-use', 'model': model, 'endpoint': endpoint, 'size': size}


def edit_image(image, prompt, output):
    cmd = [sys.executable, FALLBACK_SCRIPT, 'edit', '--image', image, prompt, '-o', output]
    r = subprocess.run(cmd, capture_output=True, text=True, timeout=1200)
    text = (r.stdout or '') + ('\n' + r.stderr if r.stderr else '')
    if r.returncode != 0:
        print(text, file=sys.stderr)
        return r.returncode
    print(text)
    return 0


def main():
    load_profile_env()
    os.makedirs(OUT_DIR, exist_ok=True)
    if len(sys.argv) < 2 or sys.argv[1] in ('-h', '--help', 'help', '帮助'):
        usage(0)
    mode = sys.argv[1]
    if mode in ('画', '生成', 'gen', 'generate'):
        if len(sys.argv) < 3:
            usage(1)
        prompt = sys.argv[2]
        output = normalize_out(sys.argv[3] if len(sys.argv) >= 4 else None, 'image2')
        prompt, optimized = optimize_prompt(prompt)
        res = minis_generate(prompt, output)
        if optimized:
            res['optimized_prompt'] = optimized
        res.update({'success': True, 'path': output})
        print(json.dumps(res, ensure_ascii=False, indent=2))
        return
    if mode in ('改', '编辑', 'edit'):
        if len(sys.argv) < 4:
            usage(1)
        image = normalize_in(sys.argv[2])
        prompt = sys.argv[3]
        output = normalize_out(sys.argv[4] if len(sys.argv) >= 5 else None, 'image2_edit')
        raise SystemExit(edit_image(image, prompt, output))
    prompt = ' '.join(sys.argv[1:])
    output = normalize_out(None, 'image2')
    prompt, optimized = optimize_prompt(prompt)
    res = minis_generate(prompt, output)
    if optimized:
        res['optimized_prompt'] = optimized
    res.update({'success': True, 'path': output})
    print(json.dumps(res, ensure_ascii=False, indent=2))


if __name__ == '__main__':
    main()
