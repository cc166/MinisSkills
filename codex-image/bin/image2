#!/usr/bin/env python3
"""codex-image skill entry point: clean /responses streaming only."""
import os
import sys
import time


def load_profile_env():
    try:
        with open('/etc/profile', encoding='utf-8', errors='ignore') as f:
            for line in f:
                line = line.strip()
                if line.startswith('export ') and '=' in line:
                    name, val = line[7:].split('=', 1)
                    name = name.strip()
                    val = val.strip()
                    if len(val) >= 2 and val[0] == val[-1] and val[0] in ('"', "'"):
                        val = val[1:-1]
                    os.environ.setdefault(name, val)
    except Exception:
        pass


def usage(code=0):
    print('''用法:
  image2 画 "提示词" [输出文件]
  image2 改 输入图 "修改要求" [输出文件]

默认:
  只使用 /responses + SSE 流式 image_generation tool 画图/改图。
  不走 minis-model-use，不走 /v1/images/generations。
  不模拟网页登录：不发浏览器 UA，不发 Origin/Referer。

环境变量:
  IMAGE2_MODEL                   可选；不设则自动取 Minis App 模型列表当前优先模型
  IMAGE2_BASE_URL=https://ai.input.im  base URL，会自动拼 /responses
  IMAGE2_RESPONSES_URL             完整 responses URL，优先级高于 BASE_URL
  IMAGE2_API_KEY                   默认 API key 变量
  IMAGE2_API_KEY_ENV               指定从哪个环境变量读取 key，例如 INPUT_API_KEY
  OPENAI_API_KEY / INPUT_API_KEY / CODEX_API_KEY  备用 key 变量
  IMAGE2_USER_AGENT                默认 Minis image2-responses/1.0
  IMAGE2_DEBUG=1                   保存 SSE 调试日志
  IMAGE2_DRY_RUN=1                 只验证 payload，不发请求
''')
    sys.exit(code)


def add_common_flags(cmd, out_dir, edit=False):
    model = os.environ.get('IMAGE2_MODEL')
    if model:
        cmd.extend(['--model', model])
    base_url = os.environ.get('IMAGE2_BASE_URL')
    if base_url:
        cmd.extend(['--base-url', base_url])
    api_key_env = os.environ.get('IMAGE2_API_KEY_ENV')
    if api_key_env:
        cmd.extend(['--api-key-env', api_key_env])
    if os.environ.get('IMAGE2_DEBUG') == '1':
        prefix = 'image2_edit_debug' if edit else 'image2_debug'
        debug_log = os.path.join(out_dir, f"{prefix}_{time.strftime('%Y%m%d_%H%M%S')}.sse")
        cmd.extend(['--debug-log', debug_log])
    return cmd


def normalize_out(path, out_dir, prefix):
    if not path:
        return os.path.join(out_dir, f"{prefix}_{time.strftime('%Y%m%d_%H%M%S')}.png")
    if os.path.dirname(path):
        return path
    return os.path.join(out_dir, path)


def normalize_in(path, out_dir):
    if os.path.exists(path):
        return path
    alt = os.path.join(out_dir, path)
    return alt if os.path.exists(alt) else path


def find_core_script():
    here = os.path.dirname(os.path.abspath(__file__))
    candidates = [
        os.path.join(os.path.dirname(here), 'scripts', 'image2_responses.py'),
        '/var/minis/skills/codex-image/scripts/image2_responses.py',
    ]
    for path in candidates:
        if os.path.exists(path):
            return path
    print('错误: 找不到 image2_responses.py；检查路径: ' + ', '.join(candidates), file=sys.stderr)
    sys.exit(1)


def main():
    load_profile_env()
    if len(sys.argv) < 2 or sys.argv[1] in ('-h', '--help', 'help', '帮助'):
        usage(0)
    mode = sys.argv[1]
    core = find_core_script()
    out_dir = "/var/minis/attachments"
    os.makedirs(out_dir, exist_ok=True)

    if mode in ('画', '生成', 'gen', 'generate'):
        if len(sys.argv) < 3:
            usage(1)
        prompt = sys.argv[2]
        output = normalize_out(sys.argv[3] if len(sys.argv) >= 4 else None, out_dir, 'image2')
        cmd = [sys.executable, core, prompt, output]
        add_common_flags(cmd, out_dir, edit=False)
        os.execv(sys.executable, cmd)

    if mode in ('改', '编辑', 'edit'):
        if len(sys.argv) < 4:
            usage(1)
        input_image = normalize_in(sys.argv[2], out_dir)
        prompt = sys.argv[3]
        output = normalize_out(sys.argv[4] if len(sys.argv) >= 5 else None, out_dir, 'image2_edit')
        cmd = [sys.executable, core, prompt, output, '--input-image', input_image]
        add_common_flags(cmd, out_dir, edit=True)
        os.execv(sys.executable, cmd)

    prompt = ' '.join(sys.argv[1:])
    output = normalize_out(None, out_dir, 'image2')
    cmd = [sys.executable, core, prompt, output]
    add_common_flags(cmd, out_dir, edit=False)
    os.execv(sys.executable, cmd)


if __name__ == '__main__':
    main()
